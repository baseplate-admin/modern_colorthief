FROM ghcr.io/cross-rs/aarch64-unknown-linux-gnu

# The cross-rs image is Ubuntu Xenial (16.04) which only has PHP 7.0 in its repos.
# We need PHP 8.x headers for the php-src crate, so we skip apt PHP entirely,
# download the source tarball for headers, and create a php-config stub.
RUN apt-get update && \
    apt-get install -y libonig-dev libclang-dev wget && \
    PHP_VER="8.2.0" && \
    wget --tries=5 -q "https://www.php.net/distributions/php-${PHP_VER}.tar.xz" -O /tmp/php.tar.xz && \
    tar xf /tmp/php.tar.xz -C /tmp && \
    mkdir -p /usr/include/php && \
    cp -r "/tmp/php-${PHP_VER}/main/"* /usr/include/php/ && \
    cp -r "/tmp/php-${PHP_VER}/Zend/"* /usr/include/php/ && \
    cp -r "/tmp/php-${PHP_VER}/TSRM/"* /usr/include/php/ && \
    cd /usr/include/php && \
    sed -e 's/#undef ZEND_SIGNALS/#define ZEND_SIGNALS 0/' \
        -e 's/#undef PHP_EXPORT_SYMBOLC/#define PHP_EXPORT_SYMBOL 1/' \
        -e 's/@ZEND_SIGNALS@/0/g' \
        -e 's/@PHP_EXPORT_SYMBOL@/1/g' \
        -e 's/@PHP_MAJOR_VERSION@/8/g' \
        -e 's/@PHP_MINOR_VERSION@/2/g' \
        -e 's/@PHP_RELEASE_VERSION@/0/g' \
        -e 's/@PHP_EXTRA_VERSION@//g' \
        -e 's/@PHP_VERSION@/8.2.0/g' \
        -e 's/@PHP_VERSION_ID@/80200/g' \
        -e 's/@PHP_BUILD_DIR@//g' \
        -e 's/@PHP_PREFIX@//g' \
        -e 's/@PHP_BINDIR@//g' \
        -e 's/@PHP_LIBDIR@//g' \
        -e 's/@PHP_MANDIR@//g' \
        -e 's/@PHP_SYSCONFDIR@//g' \
        -e 's/@PHP_LOCALSTATEDIR@//g' \
        -e 's/@PHP_CONFIG_FILE_PATH@//g' \
        -e 's/@PHP_CONFIG_FILE_SCAN_DIR@//g' \
        -e 's/@PHP_EXTENSION_DIR@//g' \
        -e 's/@EXTRA_LIBXML@//g' \
        -e 's/@LIBXML@//g' \
        -e 's/@EXTRA_LIBS@//g' \
        -e 's/@PHP_RPATH@//g' \
        -e 's/@PHP_LT_SYS_LIBDPATH@//g' \
        -e 's/@PHP_ZEND_DEBUG@/0/g' \
        -e 's/@ZEND_DEBUG@/0/g' \
        -e 's/@PHP_ZEND_DLEXPORT@//g' \
        -e 's/@PHP_DLEXPORT@//g' \
        -e 's/@PHP_DTRACE_HEADER@//g' \
        -e 's/@PHP_DTRACE_ENABLED@/0/g' \
        -e 's/@PHP_DTRACE_USDT_ENABLED@/0/g' \
        -e 's/@PHP_DEBUG@/0/g' \
        -e 's/@PHP_HAVE_BUNDLED_ZLIB@/0/g' \
        php_config.h.in > php_config.h && \
    rm -rf "/tmp/php-${PHP_VER}" /tmp/php.tar.xz

# Create a php-config stub so the php-src build script can query PHP paths
# Create a php-config stub so the build scripts can query PHP paths
RUN printf '#!/bin/sh\nprefix=/usr\nexec_prefix=/usr\nbindir=/usr/bin\nincludedir=/usr/include/php\nextension_dir=/usr/lib/php/20170718\nphpbinary=/usr/bin/php\nversion="8.2.0"\nphplibdir=/usr/lib\n\nfor arg in "$@"; do\n  case $arg in\n    --prefix) echo "$prefix" ;;\n    --exec-prefix) echo "$exec_prefix" ;;\n    --version) echo "$version" ;;\n    --includes) echo "-I$includedir/main -I$includedir" ;;\n    --extension-dir) echo "$extension_dir" ;;\n    --php-binary) echo "$phpbinary" ;;\n    --libdir) echo "$phplibdir" ;;\n    --bindir) echo "$bindir" ;;\n    --ini-path) echo "/etc/php/8.2/cli" ;;\n    --ini-dir) echo "/etc/php/8.2/cli" ;;\n    *) echo "php-config 8.2.0" ;;\n  esac\ndone\n' > /usr/bin/php-config && \
    chmod +x /usr/bin/php-config

# Create a stub php binary — ext-php-rs needs a PHP executable to query version/build info.
# This stub responds to the -r and --version flags used by the ext-php-rs build script.
RUN printf '#!/bin/sh\nif [ "$1" = "--version" ] || [ "$1" = "-v" ]; then\n  echo "PHP 8.2.0 (cli) \\n (built: fake)\\nCopyright (c) The PHP Group\\nZend Engine v4.2.0, Copyright (c) Zend Technologies"\n  exit 0\nfi\nif [ "$1" = "-r" ]; then\n  eval "$2" > /dev/null 2>&1\n  case "$2" in\n    *PHP_VERSION*) echo "8.2.0" ;;\n    *PHP_MAJOR_VERSION*) echo "8" ;;\n    *PHP_MINOR_VERSION*) echo "2" ;;\n    *PHP_RELEASE_VERSION*) echo "0" ;;\n    *PHP_EXTRA_VERSION*) echo "" ;;\n    *PHP_VERSION_ID*) echo "80200" ;;\n    *PHP_OS*) echo "Linux" ;;\n    *PHP_DATADIR*) echo "/usr/share/php" ;;\n    *PHP_LIBDIR*) echo "lib" ;;\n    *PHP_EXTENSION_DIR*) echo "/usr/lib/php/20170718" ;;\n    *PHP_CONFIG_FILE_PATH*) echo "/etc/php/8.2/cli/php.ini" ;;\n    *PHP_CONFIG_FILE_SCAN_DIR*) echo "/etc/php/8.2/cli/conf.d" ;;\n    *PHP_SHLIB_SUFFIX*) echo "so" ;;\n    *PHP_ZTS*) echo "1" ;;\n    *PHP_DEBUG*) echo "0" ;;\n    *) echo "" ;;\n  esac\n  exit 0\nfi\necho "PHP 8.2.0"\nexit 0\n' > /usr/bin/php && \
    chmod +x /usr/bin/php
