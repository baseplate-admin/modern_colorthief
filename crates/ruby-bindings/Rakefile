# frozen_string_literal: true

def build_extension
  puts "Compiling modern_colorthief Rust extension..."

  lib_dir = File.expand_path("lib/modern_colorthief")
  FileUtils.mkdir_p(lib_dir) unless File.directory?(lib_dir)

  system("cargo", "build", "--release", "--manifest-path", "ext/Cargo.toml") do |ok, status|
    abort "Cargo build failed (exit #{status.exitstatus})" unless ok
  end

  target_dir = File.expand_path("target/release")

  found = Dir.glob(File.join(target_dir, "libmodern_colorthief.*"))
    .find { |f| File.file?(f) && %w[.so .bundle .dll].any? { |ext| f.end_with?(ext) } }
  if found
    FileUtils.cp(found, lib_dir)
    puts "Copied #{File.basename(found)} to lib/modern_colorthief/"
  else
    abort "Could not find built library in #{target_dir}"
  end
end

# Tasks expected by oxidize-rb cross-gem action
%w[x86_64-linux aarch64-linux x86_64-darwin arm64-darwin x64-mingw-ucrt].each do |platform|
  Rake::Task.define_task("native:#{platform}") do
    build_extension
  end
end

# Generic build task
task :build do
  build_extension
end

task "default" => "build"
