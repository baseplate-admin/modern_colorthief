# frozen_string_literal: true

def build_extension
  puts "Compiling modern_colorthief_gpu Rust extension..."

  lib_dir = File.expand_path("lib/modern_colorthief_gpu")
  FileUtils.mkdir_p(lib_dir) unless File.directory?(lib_dir)

  cargo_args = ["build", "--release", "--manifest-path", "ext/Cargo.toml"]

  target = ENV["RB_SYS_RUBY_BUILD_TARGET"]
  if target
    cargo_args << "--target"
    cargo_args << target
    puts "Cross-compiling for target: #{target}"
  end

  system("cargo", *cargo_args) do |ok, status|
    abort "Cargo build failed (exit #{status.exitstatus})" unless ok
  end

  target_dir = target ? File.expand_path("target/#{target}/release") : File.expand_path("target/release")

  lib_name = case RbConfig::CONFIG["host_os"]
  when /linux/ then "libmodern_colorthief_gpu.so"
  when /darwin|mac/ then "libmodern_colorthief_gpu.bundle"
  when /windows|mingw/ then "modern_colorthief_gpu.dll"
  else "libmodern_colorthief_gpu.so"
  end

  src = File.join(target_dir, lib_name)
  if File.exist?(src)
    FileUtils.cp(src, lib_dir)
    puts "Copied #{lib_name} to lib/modern_colorthief_gpu/"
  else
    found = Dir.glob(File.join(target_dir, "*modern_colorthief_gpu*")).find { |f| File.file?(f) }
    if found
      FileUtils.cp(found, lib_dir)
      puts "Copied #{File.basename(found)} to lib/modern_colorthief_gpu/"
    else
      abort "Could not find built library in #{target_dir}"
    end
  end
end

# Tasks expected by oxidize-rb cross-gem action
%w[x86_64-linux aarch64-linux x86_64-darwin arm64-darwin x64-mingw-ucrt].each do |platform|
  Rake::Task.define_task("native:#{platform}") do
    build_extension
  end
end

# Generic build task
task :build do
  build_extension
end

task "default" => "build"
